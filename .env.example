# ─────────────────────────────────────────────────────────────
# Environment template — copy this file to .env and fill in values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Database — Neon PostgreSQL connection string.
# Create a project at https://neon.tech and paste its connection string here.
DATABASE_URL=""

# Auth — NextAuth session signing.
# Generate a strong secret with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# AI assistant (optional) — Groq API key for the manager chat widget.
# Get a free key (no billing) at https://console.groq.com/keys  (starts with gsk_)
# Leave blank to use the built-in local summary fallback instead of external AI.
GROQ_API_KEY=""

# Registration security — Manager/Admin public signups are pending by default.
# Set to "true" only for controlled demos where elevated signups should be auto-approved.
ALLOW_PUBLIC_ELEVATED_SIGNUP="false"